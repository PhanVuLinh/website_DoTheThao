mixin productItem (item) 
  .flash-product-card
    .flash-product-card__img-wrap
      //- span.badge.badge-orange FLASH SALE
      span.badge.badge-pink #{item.badgeText}
      img(src=item.avatar, alt=item.name)
    h3.flash-product-card__title #{item.name}
    
    ul.flash-product-card__info
      li
        i.fa-solid.fa-barcode
        | Mã SP: #{item.code}
      li
        i.fa-solid.fa-tag
        | Phân loại: #{item.feature}
      li
        i.fa-solid.fa-shield-halved
        | Bảo hành: #{item.warranty}
      li
        i.fa-solid.fa-truck-fast
        | Giao hàng: #{item.delivery}

    .flash-product-card__bottom
      .flash-product-card__price
        span.old-price #{item.priceOld.toLocaleString('vi-VN')}đ
        span.new-price #{item.priceNew.toLocaleString('vi-VN')}đ
      button.btn-cart
        i.fa-solid.fa-cart-plus

    //- Thêm khối Đánh giá và Tồn kho
    .flash-product-card__rating-stock
      .rating
        i.fa-solid.fa-star
        i.fa-solid.fa-star
        i.fa-solid.fa-star
        i.fa-solid.fa-star
        i.fa-solid.fa-star-half-stroke
        span.rating-total (1250)
      .stock
        span.stock-label Còn lại:
        span.stock-number 5
