  section.deals
    .deals__container 
      
      .deals__promo
        h2.deals__title ƯU ĐÃI 2026
        h3.deals__subtitle DEALS THỂ THAO CHÍNH HÃNG
        p.deals__desc SĂN NGAY TRƯỚC KHI HẾT HÀNG
        p.deals__text Nhanh tay sở hữu các sản phẩm thể thao chất lượng cao với giá cực tốt. Ưu đãi số lượng có hạn!
        
        .deals__countdown-title Kết thúc sau
        .countdown
          .countdown__item
            span.countdown__number 12
          .countdown__item
            span.countdown__number 20
          .countdown__item
