extends ../layouts/default.pug
include ../mixins/product-item.pug

block main
  // SECTION 1: HERO
  section.hero
    //- Ảnh nền dùng thẻ img chuẩn SEO
    img.hero__img(src="../client/assets/images/banner2.jpg" alt="TitiSport")
    
    .hero__overlay
    .hero__container 
      .hero__content
        //- Badge
        .hero__badge 
          i.fa-solid.fa-trophy
          | THẾ GIỚI ĐỒ THỂ THAO CHÍNH HÃNG
        
        //- Tiêu đề
        h1.hero__title
          | BỨT PHÁ
          br
          | MỌI GIỚI HẠN
        
        p.hero__description 
          | Trải nghiệm đẳng cấp với bộ sưu tập thể thao mới nhất. Chất lượng
          br
          | vượt trội, thiết kế tối ưu cho mọi chuyển động.
        
        .hero__search-box
          form.hero-search-form
            i.fa-solid.fa-magnifying-glass.icon-search
            input(placeholder="Bạn muốn tìm gì hôm nay?" type="text")
            button(type="submit") Tìm Kiếm

        //- Gợi ý tìm kiếm
        .hero__suggestions
          span.suggestion-label Gợi ý:
          a.suggestion-pill(href="#")
            i.fa-solid.fa-shoe-prints
            span Giày
          a.suggestion-pill(href="#")
            i.fa-solid.fa-shirt
            span Quần áo
          a.suggestion-pill(href="#")
            i.fa-solid.fa-volleyball
            span Phụ kiện
  // END SECTION 1: HERO

  // SECTION 2: CATEGORIES
  section.categories
    .categories__container
      
      //- Phần tiêu đề và nút xem tất cả
      .categories__header
        .categories__title-wrap
          span.categories__subtitle DANH MỤC
          h2.categories__title Khám Phá Bộ Sưu Tập
        a.categories__view-all(href="#")
          | Xem Tất Cả
          i.fa-solid.fa-arrow-right-long

      //- Lưới chứa 4 danh mục
      .categories__grid
        // Item 1: Giày Thể Thao
        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1000&auto=format&fit=crop", alt="Giày Thể Thao")
          h3.category-card__title Giày Thể Thao
          span.category-card__count 245 Sản phẩm

        // Item 2: Quần Áo
        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1556821840-3a63f95609a7?q=80&w=1000&auto=format&fit=crop", alt="Quần Áo")
          h3.category-card__title Quần Áo
          span.category-card__count 189 Sản phẩm

        // Item 3: Phụ Kiện
        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1000&auto=format&fit=crop", alt="Phụ Kiện")
          h3.category-card__title Phụ Kiện
          span.category-card__count 542 Sản phẩm

        // Item 4: Dụng Cụ Tập
        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1622279457486-62dcc4a431d6?q=80&w=1000&auto=format&fit=crop", alt="Dụng Cụ Tập")
          h3.category-card__title Dụng Cụ Tập
          span.category-card__count 76 Sản phẩm
  // END SECTION 2: CATEGORIES
  // SECTION 3: FLASH DEALS
