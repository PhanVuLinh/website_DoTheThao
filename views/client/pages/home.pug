extends ../layouts/default.pug
include ../mixins/product-item.pug

block main
  // SECTION 1: HERO
  section.hero
    img.hero__img(src="../client/assets/images/banner2.jpg" alt="TitiSport")
    
    .hero__overlay
    .hero__container 
      .hero__content
        .hero__badge 
          i.fa-solid.fa-trophy
          | THẾ GIỚI ĐỒ THỂ THAO CHÍNH HÃNG
        h1.hero__title
          | BỨT PHÁ
          br
          | MỌI GIỚI HẠN
        p.hero__description 
          | Trải nghiệm đẳng cấp với bộ sưu tập thể thao mới nhất. Chất lượng
          br
          | vượt trội, thiết kế tối ưu cho mọi chuyển động.
        
        .hero__search-box
          form.hero-search-form
            i.fa-solid.fa-magnifying-glass.icon-search
            input(placeholder="Bạn muốn tìm gì hôm nay?" type="text")
            button(type="submit") Tìm Kiếm
        .hero__suggestions
          span.suggestion-label Gợi ý:
          a.suggestion-pill(href="#")
            i.fa-solid.fa-shoe-prints
            span Giày
          a.suggestion-pill(href="#")
            i.fa-solid.fa-shirt
            span Quần áo
          a.suggestion-pill(href="#")
            i.fa-solid.fa-volleyball
            span Phụ kiện
  // END SECTION 1: HERO

  // SECTION 2: CATEGORIES
  section.categories
    .categories__container
      .categories__header
        .categories__title-wrap
          span.categories__subtitle DANH MỤC
          h2.categories__title Khám Phá Bộ Sưu Tập
        a.categories__view-all(href="#")
          | Xem Tất Cả
          i.fa-solid.fa-arrow-right-long

      .categories__grid
        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=1000&auto=format&fit=crop", alt="Giày Thể Thao")
          h3.category-card__title Giày Thể Thao
          span.category-card__count 245 Sản phẩm

        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1556821840-3a63f95609a7?q=80&w=1000&auto=format&fit=crop", alt="Quần Áo")
          h3.category-card__title Quần Áo
          span.category-card__count 189 Sản phẩm

        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?q=80&w=1000&auto=format&fit=crop", alt="Phụ Kiện")
          h3.category-card__title Phụ Kiện
          span.category-card__count 542 Sản phẩm

        a.category-card(href="#")
          .category-card__img-wrap
            img(src="https://images.unsplash.com/photo-1622279457486-62dcc4a431d6?q=80&w=1000&auto=format&fit=crop", alt="Dụng Cụ Tập")
          h3.category-card__title Dụng Cụ Tập
          span.category-card__count 76 Sản phẩm
  // END SECTION 2: CATEGORIES

  // SECTION 3: FLASH DEALS
  section.flash-deals
    .flash-deals__container
      .flash-promo
        .flash-promo__badge
          i.fa-solid.fa-bolt
          | ƯU ĐÃI 2026
        h2.flash-promo__title-new
          | DEALS THỂ THAO
          br
          | CHÍNH HÃNG
        p.flash-promo__countdown-label Kết thúc sau:
        .flash-promo__countdown
          .countdown-box
            span.num 12
            span.label GIỜ
          span.colon :
          .countdown-box
            span.num 20
            span.label PHÚT
          span.colon :
          .countdown-box
            span.num 30
            span.label GIÂY

      .flash-products-wrapper
        button.slider-btn.prev-btn
          i.fa-solid.fa-chevron-left
        .flash-products-list
          each item in productListSection3
            .flash-product-item
              +productItem(item)
        button.slider-btn.next-btn
          i.fa-solid.fa-chevron-right
  // END SECTION 3: FLASH DEALS

  // SECTION 4: KHUYẾN MẠI THỂ THAO
  section.promotions
    .promotions__container
      h2.promotions__title Siêu Sale Thể Thao - Bứt Phá Giới Hạn
      .promotions__slider
        .promotions__list#promo-track
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1556906781-9a412961c28c?q=80&w=800&auto=format&fit=crop", alt="Sale Giày Chạy Bộ")
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1511886929837-354d827aae26?q=80&w=800&auto=format&fit=crop", alt="Bộ Sưu Tập Bóng Đá Mùa Giải Mới")
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800&auto=format&fit=crop", alt="Thời trang Gym & Training")
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1546519638-68e109498ffc?q=80&w=800&auto=format&fit=crop", alt="Đồ Bóng Rổ & Phụ Kiện")
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1483721310020-03333e577078?q=80&w=800&auto=format&fit=crop", alt="Quần Áo Thể Thao Nữ")
          .promotions__item
            a(href="#")
              img(src="https://images.unsplash.com/photo-1575361204480-aadea25e6e68?q=80&w=800&auto=format&fit=crop", alt="Vợt & Phụ kiện Cầu Lông")

      //- Khối chấm tròn (Pagination dots)
      .promotions__dots#promo-dots
        span.dot.active(data-index="0")
        span.dot(data-index="1")
        span.dot(data-index="2")
        span.dot(data-index="3")
  // END SECTION 4

  // SECTION 5: SẢN PHẨM NỔI BẬT
  section.featured-products
    .featured-products__container
      h2.section-title Sản Phẩm Nổi Bật
      
      .featured-products__grid
        each item in productFeaturedSection5
          +productItem(item)

      .featured-products__actions
        a.btn-view-all-outline(href="#") 
          | Xem Tất Cả 
          i.fa-solid.fa-arrow-right-long
  // END SECTION 5

  // SECTION 6: BANNER QUẢNG CÁO
  section.banner-promo(data-aos="fade-up" data-aos-duration="800")
    .banner-promo__container
      .banner-promo__inner
        a(href="#")
          img(src="https://giayhaanh.vn/wp-content/uploads/2025/10/banner-quang-cao-giay-the-thao-voi-hinh-anh-an-tuong-va-thong-diep-ro-rang.jpg", alt="Banner Khuyến Mãi Thể Thao")
  // END SECTION 6

  // SECTION 7: SẢN PHẨM MỚI NHẤT
  section.featured-products
    .featured-products__container
      h2.section-title Sản Phẩm Mới Nhất
      
      .featured-products__grid
        each item in productListSection7
          +productItem(item)

      .featured-products__actions
        a.btn-view-all-outline(href="#") 
          | Xem Tất Cả 
          i.fa-solid.fa-arrow-right-long
    // END SECTION 7

    // SECTION 9: TIN TỨC MỚI (CHỦ ĐỀ BÓNG ĐÁ & BÓNG CHUYỀN)
  -
    var newsCenter = {
      image: "https://images.unsplash.com/photo-1614632537197-38a17061c2bd?q=80&w=800&auto=format&fit=crop", // Ảnh giày đá bóng đinh
      date: "28/03/2026",
      title: "Top 5 Mẫu Giày Đá Bóng Sân Cỏ Nhân Tạo Đáng Mua Nhất 2026",
      desc: "Khám phá những siêu phẩm giày bóng đá đinh dăm (TF) từ Nike, Adidas, Puma giúp bạn bứt tốc, bám sân và kiểm soát bóng cực đỉnh trên mặt sân nhân tạo..."
    }
    
    var newsLeft = [
      {
        image: "https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?q=80&w=500&auto=format&fit=crop", // Ảnh đập bóng chuyền
        date: "25/03/2026",
        title: "Bí Quyết Chọn Bóng Chuyền Hơi & Da Chuẩn Cảm Giác Thi Đấu"
      },
      {
        image: "https://images.unsplash.com/photo-1508344928928-7165b67de128?q=80&w=500&auto=format&fit=crop", // Ảnh áo bóng đá
        date: "22/03/2026",
        title: "Hướng Dẫn Chọn Quần Áo Bóng Đá Thoáng Khí Cho Mùa Hè Oi Bức"
      }
    ]
    
    var newsRight = [
      {
        image: "https://images.unsplash.com/photo-1592656094267-764a45160876?q=80&w=500&auto=format&fit=crop", // Ảnh sân bóng chuyền
        date: "20/03/2026",
        title: "Các Loại Bó Gối, Phụ Kiện Không Thể Thiếu Cho Dân Đập Bóng"
      },
      {
        image: "https://images.unsplash.com/photo-1553775282-20af80779df7?q=80&w=500&auto=format&fit=crop", // Ảnh găng tay thủ môn
        date: "18/03/2026",
        title: "Đánh Giá Chi Tiết Dòng Găng Tay Thủ Môn Predator Cực Dính"
      }
    ]

  section.news-section(data-aos="fade-up" data-aos-duration="800")
    .news-section__container
      h2.section-title Tin Tức Mới
      
      .news-grid
        // Cột Trái (2 bài nhỏ)
        .news-col.news-col--side
          each item in newsLeft
            a.news-card-small(href="#")
              img(src=item.image, alt=item.title)
              .news-card-small__overlay
                span.date= item.date
                h4.title= item.title

        // Cột Giữa (1 bài lớn)
        .news-col.news-col--center
          article.news-card-large
            a.news-card-large__img(href="#")
              img(src=newsCenter.image, alt=newsCenter.title)
            .news-card-large__content
              span.date= newsCenter.date
              h3.title
                a(href="#")= newsCenter.title
              p.desc= newsCenter.desc

        // Cột Phải (2 bài nhỏ)
        .news-col.news-col--side
          each item in newsRight
            a.news-card-small(href="#")
              img(src=item.image, alt=item.title)
              .news-card-small__overlay
                span.date= item.date
                h4.title= item.title
  // END SECTION 9
    