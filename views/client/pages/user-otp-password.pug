extends ../layouts/default.pug

block main
  .auth-page
    .container
      .auth-box
        h2.auth-title Xác Thực OTP
        p.auth-subtitle Vui lòng nhập mã gồm 6 chữ số vừa được gửi đến email của bạn.
        
        form(action="/auth/otp-password" method="POST")
          
          .form-group
            label(for="email") Email nhận mã
            input#email.form-control(
              type="email" 
              name="email" 
              value=email 
              readonly 
              style="background-color: #f0f0f0; color: #888; cursor: not-allowed;"
            )

          .form-group
            label(for="otp") Mã OTP
            input#otp.form-control.otp-single-input(
              type="text" 
              name="otp" 
              maxlength="6" 
              placeholder="Nhập 6 số..."
              pattern="[0-9]*" 
              inputmode="numeric" 
              required
            )
              
          button.btn-auth(type="submit") 
            | Xác Nhận
            