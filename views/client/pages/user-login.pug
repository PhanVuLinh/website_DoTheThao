extends ../layouts/default.pug

block main
  .auth-page
    .container
      .auth-box
        h2.auth-title Đăng Nhập
        p.auth-subtitle Chào mừng bạn trở lại với #{settingWebsiteInfo.websiteName}
        
        form(action="/auth/login" method="POST")
          .form-group
            label(for="email") Email
            input#email.form-control(type="email" name="email" placeholder="Nhập email của bạn" value=oldData.email || "")
            
          .form-group
            label(for="password") Mật khẩu
            input#password.form-control(type="password" name="password" placeholder="Nhập mật khẩu")
            
          .auth-options
            label.remember-me
              input(type="checkbox" name="remember") 
              | Ghi nhớ đăng nhập
            a.forgot-link(href="/auth/forgot-password") Quên mật khẩu?
            
          button.btn-auth(type="submit") 
            | Đăng Nhập
            
        .auth-redirect
          | Bạn chưa có tài khoản? 
          a(href="/auth/register") Đăng ký ngay