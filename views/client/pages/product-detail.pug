extends ../layouts/default.pug
include ../mixins/box-breadcrumb.pug

block main 
  //- GIẢ LẬP DỮ LIỆU TỪ DB (Xóa khối này khi ghép API thực tế)
  -
    var product = {
      title: "Áo thun thể thao nam Adidas Aeroready",
      images: [
        "https://picsum.photos/id/237/1000/1000",
        "https://picsum.photos/id/238/1000/1000",
        "https://picsum.photos/id/239/1000/1000",
        "https://picsum.photos/id/240/1000/1000"
      ],
      thumbnail: "https://res.cloudinary.com/dywi6r8jx/image/upload/v1776099415/grft4ayct89mv3owioyc.webp",
      price: 850000,
      description: "Áo thun tập luyện nam Adidas...",
      sizes: [
        { size: "size: M", stock: 30 },
        { size: "size: L", stock: 20 },
        { size: "size: XL", stock: 12 }
      ]
    };
    
    var formatCurrency = (amount) => {
      return amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".") + "đ";
    };

  +box-breadcrumb(breadcrumb)

  // SECTION: CHI TIẾT SẢN PHẨM
  section.product-detail-page
    .container
      .detail-grid
        
        // --- CỘT TRÁI: HÌNH ẢNH & THÔNG TIN ---
        .detail-left
          .detail-card.product-image-card
            //- Slider Ảnh Chính
            .swiper.main-swiper
              .swiper-wrapper
                each img in product.images
                  - var mainUrl = img.includes('/upload/') ? img.replace('/upload/', '/upload/w_800,c_limit,q_auto,f_auto/') : img
                  .swiper-slide
                    img(src=mainUrl, alt=product.title)
            
              //- Nút Next/Prev
              .swiper-button-next
              .swiper-button-prev

            //- Slider Ảnh Thumbs (Nhỏ)
            .swiper.thumb-swiper
              .swiper-wrapper
                each img in product.images
                  - var thumbUrl = img.includes('/upload/') ? img.replace('/upload/', '/upload/w_150,h_100,c_fill,q_auto,f_auto/') : img
                  .swiper-slide
                    img(src=thumbUrl, alt=product.title)

          //- Thông tin mô tả
          .detail-card.info-card
            h3.card-title
              i.fa-solid.fa-circle-info
              | Thông Tin Chi Tiết
            p.info-desc= product.description

        // --- CỘT PHẢI: FORM ĐẶT HÀNG ---
        .detail-right
          .booking-card
            
            // Header Sản phẩm
            .product-header
              h1.product-title= product.title
              
              .product-meta-top
                .stars
                  i.fa-solid.fa-star
                  i.fa-solid.fa-star
                  i.fa-solid.fa-star
                  i.fa-solid.fa-star
                  i.fa-solid.fa-star
                  span (Chưa có đánh giá)
                span.divider |
                .status
                  i.fa-solid.fa-check-circle
                  | Còn hàng

            // Giá tiền nổi bật
            .price-wrap
              .current-price= formatCurrency(product.price)

            // Chọn Size
            .form-group.size-selection
              label Kích Thước (Size)
              .filter-grid-size
                if product.sizes && product.sizes.length > 0
                  each item, index in product.sizes
                    - var sizeLabel = item.size.replace("size: ", "").trim();
                    div.size-item
                      input(
                        type="radio", 
                        id=`size-${sizeLabel}`, 
                        name="size", 
                        value=sizeLabel, 
                        checked=(index === 0), 
                        data-stock=item.stock
                      )
                      label.size-btn(for=`size-${sizeLabel}`) #{sizeLabel}
                else 
                  p.text-danger Sản phẩm tạm hết hàng.

            // Chọn số lượng
            .form-group.qty-selection
              label Số lượng
              
              - var initialStock = product.sizes && product.sizes.length > 0 ? product.sizes[0].stock : 1;
              
              .qty-control-wrapper
                .qty-custom
                  button.btn-qty-custom.minus(type="button") -
                  input#quantity(type="text", value="1", readonly)
                  button.btn-qty-custom.plus(type="button") +
                
                span.stock-info
                  | Còn <strong id="current-stock">#{initialStock}</strong> sản phẩm

            // Nút Thêm vào giỏ hàng
            button.btn-submit-cart 
              i.fa-solid.fa-cart-plus
              | Thêm Vào Giỏ Hàng

            // Trust Badges (Cam kết)
            .trust-badges
              .trust-item
                .icon-box
                  i.fa-solid.fa-shield-halved
                span Cam kết 100% chính hãng
              
              .trust-item
                .icon-box
                  i.fa-solid.fa-rotate-left
                span Đổi trả miễn phí trong 7 ngày
              
              .trust-item
                .icon-box
                  i.fa-solid.fa-truck-fast
                span Miễn phí vận chuyển toàn quốc