extends ../layouts/default.pug

block main 
  section.cart-page
    .container
      .cart-container
        
        // --- KHỐI 1: DANH SÁCH SẢN PHẨM & TÍNH TIỀN ---
        .cart-box
          .cart-box__header
            h2.title Giỏ Hàng
            a.continue-link(href="/products") Quay lại mua hàng <i class="fa-solid fa-angle-right"></i>
          
          .cart-list
            // Item 1
            .cart-item
              .cart-item__checkbox
                input(type="checkbox" checked)
              img.cart-item__img(src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=200&auto=format&fit=crop" alt="Nike Air Zoom")
              
              .cart-item__info
                h3.name Giày Chạy Bộ Nike Air Zoom Pegasus 40 Đỏ
                p.variant Phân loại: Size 41
              
              .cart-item__action
                .qty-control
                  button.btn-qty.minus -
                  input(type="number" value="1" min="1")
                  button.btn-qty.plus +
                .item-price 3.800.000 đ

          // Khối Nhập Mã Giảm Giá
          .cart-discount-row
            .discount-input-wrap
              input(type="text" placeholder="Nhập mã giảm giá")
              button.btn-apply Dùng Mã

          // Tổng kết tiền
          .cart-summary
            .summary-row
              span Tổng tiền:
              span 3.800.000 đ
            .summary-row
              span Giảm:
              span 0 đ
            .summary-row.total
              span Thanh toán:
              strong.price-red 3.800.000 đ

        // --- KHỐI 2: THÔNG TIN KHÁCH HÀNG & THANH TOÁN ---
        .cart-box.checkout-box
          h2.title Thông Tin Giao Hàng
          
          form.checkout-form(action="/checkout" method="POST")
            .form-grid
              .form-group
                input.form-control(type="text" placeholder="Họ và tên *" required)
              .form-group
                input.form-control(type="text" placeholder="Số điện thoại *" required)
            .form-group
              input.form-control(type="text" placeholder="Địa chỉ nhận hàng chi tiết *" required)
            .form-group
              textarea.form-control(placeholder="Ghi chú thêm (Tùy chọn)" rows="3")
            
            h3.subtitle Chọn phương thức thanh toán
            .payment-methods
              label.payment-option
                input(type="radio" name="payment" value="cod" checked)
                span Thanh toán tiền mặt khi nhận hàng (COD)
              label.payment-option
                input(type="radio" name="payment" value="momo")
                span Ví MoMo
              label.payment-option
                input(type="radio" name="payment" value="bank")
                span Chuyển khoản ngân hàng

            button.btn-submit-order(type="submit") ĐẶT HÀNG