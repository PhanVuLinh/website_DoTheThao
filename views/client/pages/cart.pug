extends ../layouts/default.pug

block main 
  section.cart-page
    .container
      .cart-container
        if(cartDetail.products.length > 0)
          .cart-box
            .cart-box__header
              h2.title Giỏ Hàng
              a.continue-link(href="/") Quay lại mua hàng <i class="fa-solid fa-angle-right"></i>
            
            .cart-list
              each item in cartDetail.products
                .cart-item(data-price-new=item.productInfo.priceNew style="position: relative;")
                  a.btn-delete(
                    href=`/cart/delete/${item.product_id}`
                    style="position: absolute; top: 10px; right: 10px; color: #999; text-decoration: none; font-size: 1.2rem;"
                  ) 
                    i.fa-solid.fa-xmark
                  .cart-item__checkbox
                    input(type="checkbox" checked)
                  a(href=`/product/detail/${item.productInfo.slug}`)
                    img.cart-item__img(src=item.productInfo.thumbnail alt=item.productInfo.title)
                  
                  .cart-item__info
                    a(href=`/product/detail/${item.productInfo.slug}`)
                      h3.name #{item.productInfo.title}
                    p.variant Phân loại: #{item.size}

                  
                  .cart-item__action
                    .qty-control
                      button.btn-qty.minus -
                      input.qty-input(type="number" name="quantity" value=item.quantity product-id=item.product_id min="1")
                      button.btn-qty.plus +
                    .item-price #{item.totalPrice.toLocaleString('vi-VN')} đ
            .cart-discount-row
              .discount-input-wrap
                if cartDetail.coupon && cartDetail.coupon.code
                  input#coupon-input(type="text" value=cartDetail.coupon.code readonly)
                  button.btn-apply#btn-apply-coupon(type="button" style="display: none;") Dùng Mã
                  button#btn-cancel-coupon(type="button" style="display: block; background: #dc3545; color: white; border: none; padding: 0 20px; border-radius: 0 6px 6px 0; font-weight: 700; cursor: pointer;") Hủy
                else
                  input#coupon-input(type="text" placeholder="Nhập mã giảm giá")
                  button.btn-apply#btn-apply-coupon(type="button" style="display: block;") Dùng Mã
                  button#btn-cancel-coupon(type="button" style="display: none; background: #dc3545; color: white; border: none; padding: 0 20px; border-radius: 0 6px 6px 0; font-weight: 700; cursor: pointer;") Hủy
            .cart-summary 
              input#subtotal-raw(type="hidden" value=cartDetail.totalPrice)
              .summary-row
                span Tạm tính:
                .inner-price
                  span.cart-total #{cartDetail.totalPrice.toLocaleString('vi-VN')} đ
              
              //- ĐÃ SỬA: Bổ sung data-percent, data-max và logic tự động hiện nếu có mã
              .summary-row#discount-row(
                style=(cartDetail.discountAmount > 0 ? "display: flex;" : "display: none;")
                data-percent=(cartDetail.couponInfo ? cartDetail.couponInfo.discountPercentage : 0)
                data-max=(cartDetail.couponInfo ? cartDetail.couponInfo.maxDiscountAmount : 0)
              )
                span Giảm:
                span#discount-val(style="color: red;") - #{cartDetail.discountAmount ? cartDetail.discountAmount.toLocaleString('vi-VN') : 0} đ
              
              .summary-row.total
                span Thanh toán:
                strong.price-red
                  span#total-val.cart-total #{cartDetail.totalPayment ? cartDetail.totalPayment.toLocaleString('vi-VN') : cartDetail.totalPrice.toLocaleString('vi-VN')} đ
          .cart-box.checkout-box
            h2.title Thông Tin Giao Hàng
            form.checkout-form(action="/order/create" method="POST")
              .form-grid
                .form-group
                  input.form-control(type="text" name="fullName" placeholder="Họ và tên *" required)
                .form-group
                  input.form-control(type="text" name="phone" placeholder="Số điện thoại *" required)
              .form-group
                input.form-control(type="text" name="address" placeholder="Địa chỉ nhận hàng chi tiết *" required)
              .form-group
                textarea.form-control(name="note" placeholder="Ghi chú thêm (Tùy chọn)" rows="3")
              
              h3.subtitle Chọn phương thức thanh toán
              .payment-methods
                label.payment-option
                  input(type="radio" name="paymentMethod" value="cod" checked)
                  span Thanh toán tiền mặt khi nhận hàng (COD)
                label.payment-option
                  input(type="radio" name="paymentMethod" value="zaloPay")
                  span ZaloPay
                label.payment-option
                  input(type="radio" name="paymentMethod" value="vnPay")
                  span VNPay
                label.payment-option
                  input(type="radio" name="paymentMethod" value="momo")
                  span Ví MoMo

              button.btn-submit-order(type="submit") ĐẶT HÀNG
        else 
          p Chưa có sản phẩm trong giỏ hàng 
  script(src="/client/assets/js/cart.js")