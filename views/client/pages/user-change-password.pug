extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/profile-sidebar.pug

block main 
  +alert-success(3000)
  +alert-error(3000)
  
  .profile-page
    .container
      .profile-grid
        +profileSidebar(user, 'change-password')

        .detail-card
          h2.subtitle Đổi Mật Khẩu
          
          form(action="/user/password/edit?_method=PATCH" method="POST")
            .form-grid
              .form-group
                label(for="currentPassword") Mật khẩu hiện tại *
                input#currentPassword.form-control(
                  type="password" 
                  name="currentPassword" 
                  placeholder="Nhập mật khẩu hiện tại" 
                  required
                )
              
              .form-group
                label(for="newPassword") Mật khẩu mới *
                input#newPassword.form-control(
                  type="password" 
                  name="newPassword" 
                  placeholder="Nhập mật khẩu mới" 
                  required
                )
                
              .form-group
                label(for="confirmPassword") Xác nhận mật khẩu mới *
                input#confirmPassword.form-control(
                  type="password" 
                  name="confirmPassword" 
                  placeholder="Nhập lại mật khẩu mới" 
                  required
                )
                
            .form-group(style="margin-top: 20px;")
              button.btn-submit-cart(type="submit" style="width: max-content; padding: 14px 40px; font-size: 16px;") 
                | Cập Nhật Mật Khẩu