extends ../layouts/default.pug 
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/filter-status.pug
include ../mixins/filter-created-by.pug
include ../mixins/filter-date-range.pug
include ../mixins/category-tree.pug

block main
  if(role && role.permissions && role.permissions.includes("category_view"))
    +alert-success(3000)
    +alert-error(3000)
    h1.page-title Quản lý danh mục

    .filter-action-card
      .filter-row
        .filter-label
          i.fa-solid.fa-filter
          span Bộ lọc

        +filter-status()
        
        +filter-created-by(accountAdminList)
        
        +filter-date-range()
        
        button.btn-clear(filter-reset-category)
          i.fa-solid.fa-rotate-right
          | Xóa bộ lọc

      .filter-row
        .filter-label
          i.fa-solid.fa-folder-tree
          span Danh mục

        select.form-select(filter-category style="border: 2px solid #466BD6; font-weight: 600; color: #466BD6;")
          if parentCategoryList
            each item in parentCategoryList
              option(
                value=item.id 
                selected=(categoryId == item.id ? true : false)
              ) #{item.title}

      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("category_delete")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa" });
            }
            if(role.permissions.includes("category_edit")) {
              bulkOptions.push({ value: "active", label: "Hoạt động" });
              bulkOptions.push({ value: "inactive", label: "Dừng hoạt động" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)
        
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm danh mục..." search)
        
        .action-buttons-right
          if(role && role.permissions && role.permissions.includes("category_create"))
            a(href=`/${pathAdmin}/category/create`).btn-create
              i.fa-solid.fa-plus
              | Tạo mới

          if(role && role.permissions && role.permissions.includes("category_trash"))
            a(href=`/${pathAdmin}/category/trash`).btn-trash
              i.fa-regular.fa-trash-can
              | Thùng rác

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Tên danh mục
              th Ảnh đại diện
              th Vị trí
              th Trạng thái
              th Tạo bởi
              th Cập nhật bởi
              if(role && role.permissions && (role.permissions.includes("category_edit") || role.permissions.includes("category_delete")))
                th Hành động
          tbody
            +category-tree(categoryList)
            
    if(role && role.permissions && role.permissions.includes("category_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/category/delete`
      )
            
    if(role && role.permissions && (role.permissions.includes("category_edit") || role.permissions.includes("category_delete")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/category/change-multi`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.