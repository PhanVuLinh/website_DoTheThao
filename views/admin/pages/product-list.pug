extends ../layouts/default.pug

block main
  h1.page-title Quản lý sản phẩm

  //- 1. KHỐI BỘ LỌC VÀ HÀNH ĐỘNG
  .filter-action-card
    .filter-row
      .filter-label
        i.fa-solid.fa-filter
        span Bộ lọc
      
      select.form-select
        option(value="") Trạng thái
        option(value="active") Hoạt động
        option(value="inactive") Tạm dừng
        
      select.form-select
        option(value="") Người tạo
        option Lê Văn A
        option Lê Văn B
        
      .date-range-picker
        input(type="text" placeholder="dd/mm/yyyy")
        span -
        input(type="text" placeholder="dd/mm/yyyy")
        
      //- Thêm lọc theo Danh mục
      select.form-select
        option(value="") Danh mục
        option Giày Chạy Bộ
        option Quần Áo
        
      //- Thêm lọc theo Mức giá
      select.form-select
        option(value="") Mức giá
        option Dưới 1 triệu
        option 1 - 3 triệu
        option Trên 3 triệu
        
      button.btn-clear
        i.fa-solid.fa-rotate-right
        | Xóa bộ lọc

    //- Hàng dưới: Hành động, Tìm kiếm, Tạo mới & Thùng rác
    .action-row
      .bulk-action
        select.form-select
          option(value="") -- Hành động --
          option(value="delete") Xóa nhiều
          option(value="active") Đổi trạng thái
        button.btn-apply Áp dụng
        
      .search-box-large
        i.fa-solid.fa-magnifying-glass
        input(type="text" placeholder="Tìm kiếm sản phẩm...")
        
      .action-buttons-right
        a(href=`/${pathAdmin}/product/create`).btn-create
          i.fa-solid.fa-plus
          | Tạo mới
        a(href=`/${pathAdmin}/product/trash`).btn-trash
          i.fa-regular.fa-trash-can
          | Thùng rác

  //- 2. BẢNG DỮ LIỆU
  .table-section
    .table-responsive
      table.admin-table.table-hover
        thead
          tr
            th.text-center(width="50px")
              input(type="checkbox")
            th Tên sản phẩm
            th Ảnh đại diện
            th Giá (VNĐ)
            th Tồn kho
            th Vị trí
            th Trạng thái
            th Tạo bởi
            th Cập nhật bởi
            th Hành động
        
        tbody
          each item in products
            tr
              td.text-center
                input(type="checkbox")
              td.font-weight-600 #{item.title}
              td
                img.td-thumbnail(src=item.thumbnail alt=item.title)
              
              td.text-price #{item.price.toLocaleString('vi-VN')}đ
              
              td
                .inventory-list
                  each size in item.sizes
                    .inventory-item
                      span #{size.size}
                      span #{size.stock}
                    
              td #{item.position}
              td 
                  span(class=`badge-status ${item.status === 'active' ? 'badge-active' : 'badge-inactive'}`) #{item.status === 'active' ? 'Hoạt động' : 'Tạm dừng'}
              td
                .user-date
                  if item.createdBy && item.createdBy.account_id
                    span.name #{item.createdBy.account_id.fullName || 'Admin'}
                  if item.createdBy && item.createdBy.createdAt
                    span.time #{new Date(item.createdBy.createdAt).toLocaleString('vi-VN', { hour: '2-digit', minute:'2-digit', day:'2-digit', month:'2-digit', year:'numeric' })}
              
              td
                .user-date
                  if item.updatedBy && item.updatedBy.length > 0
                    - const lastUpdate = item.updatedBy.slice(-1)[0]
                    if lastUpdate.account_id
                      span.name #{lastUpdate.account_id.fullName || 'Admin'}
                    else
                      span.name Không rõ
                    if lastUpdate.updatedAt
                      span.time #{new Date(lastUpdate.updatedAt).toLocaleString('vi-VN', { hour: '2-digit', minute:'2-digit', day:'2-digit', month:'2-digit', year:'numeric' })}
                  else
                    span.name(style="color: #999; font-style: italic;") Chưa cập nhật
              td
                .action-btns
                  button.btn-edit(title="Sửa"): i.fa-regular.fa-pen-to-square
                  button.btn-delete(title="Xóa"): i.fa-regular.fa-trash-can

          

    //- 3. PHÂN TRANG (PAGINATION)
    .admin-pagination
      ul.pagination-list
        li.page-item.disabled
          a.page-link(href="#")
            i.fa-solid.fa-angle-left
        li.page-item.active
          a.page-link(href="#") 1
        li.page-item
          a.page-link(href="#") 2
        li.page-item
          a.page-link(href="#") 3
        li.page-item.dots
          span ...
        li.page-item
          a.page-link(href="#") 10
        li.page-item
          a.page-link(href="#")
            i.fa-solid.fa-angle-right