extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/filter-status.pug
include ../mixins/filter-created-by.pug
include ../mixins/filter-date-range.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("product_view"))
    +alert-success(3000)
    +alert-error(3000)
    h1.page-title Quản lý sản phẩm

    .filter-action-card
      .filter-row
        .filter-label
          i.fa-solid.fa-filter
          span Bộ lọc
        
        +filter-status()
          
        +filter-created-by(accountAdminList)
          
        +filter-date-range()
          
        select.form-select(filter-category)
          option(value="") Danh mục
          if categoryList
            each item in categoryList
              option(
                value=item.id 
                selected=(categoryId == item.id ? true : false)
              ) #{item.title}
          
        select.form-select(filter-price)
          option(value="") Mức giá
          option(value="0-1000000" selected=(price == "0-1000000")) Dưới 1 triệu
          option(value="1000000-3000000" selected=(price == "1000000-3000000")) 1 - 3 triệu
          option(value="3000000-" selected=(price == "3000000-")) Trên 3 triệu
                
        button.btn-clear(filter-reset)
          i.fa-solid.fa-rotate-right
          | Xóa bộ lọc

      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("product_delete")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa" });
            }
            if(role.permissions.includes("product_edit")) {
              bulkOptions.push({ value: "active", label: "Hoạt động" });
              bulkOptions.push({ value: "inactive", label: "Dừng hoạt động" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)
          
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm sản phẩm..." search)
          
        .action-buttons-right
          if(role && role.permissions && role.permissions.includes("product_create"))
            a(href=`/${pathAdmin}/product/create`).btn-create
              i.fa-solid.fa-plus
              | Tạo mới
          if(role && role.permissions && role.permissions.includes("product_trash"))
            a(href=`/${pathAdmin}/product/trash`).btn-trash
              i.fa-regular.fa-trash-can
              | Thùng rác

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Tên sản phẩm
              th Ảnh đại diện
              th Giá (VNĐ)
              th Tồn kho
              th Vị trí
              th Trạng thái
              th Tạo bởi
              th Cập nhật bởi
              if(role && role.permissions && (role.permissions.includes("product_edit") || role.permissions.includes("product_delete")))
                th Hành động
            
          tbody
            each item in productList
              tr
                td.text-center
                  input(type="checkbox" value=item.id name="id" check-item)
                td.font-weight-600 #{item.title}
                td
                  img.td-thumbnail(src=item.thumbnail alt=item.title)
                
                td.text-price #{item.price.toLocaleString('vi-VN')}đ
                
                td
                  .inventory-list
                    each size in item.sizes
                      .inventory-item
                        span #{size.size}
                        span #{size.stock}
                      
                td #{item.position}
                td 
                  span(class=`badge-status ${item.status === 'active' ? 'badge-active' : 'badge-inactive'}`) #{item.status === 'active' ? 'Hoạt động' : 'Tạm dừng'}
                td
                  .user-date
                    span.name #{item.createdByFullName}
                    span.time #{item.createdAtFormat}
                
                td
                  .user-date
                    span.name #{item.updatedByFullName}
                    span.time #{item.updatedAtFormat}
                if(role && role.permissions && (role.permissions.includes("product_edit") || role.permissions.includes("product_delete")))
                  td
                    .action-btns
                      if(role && role.permissions && role.permissions.includes("product_edit"))
                        a(href=`/${pathAdmin}/product/edit/${item.id}`).btn-edit
                          i.fa-regular.fa-pen-to-square
                      if(role && role.permissions && role.permissions.includes("product_delete"))
                        button.btn-delete(button-delete data-id=item.id)
                          i.fa-regular.fa-trash-can
            

    .admin-pagination
      +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("product_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/product/delete`
      )
              
    if(role && role.permissions && (role.permissions.includes("product_edit") || role.permissions.includes("product_delete")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/product/change-multi`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.