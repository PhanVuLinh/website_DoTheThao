extends ../layouts/default.pug

block main
  .page-header
    h1.page-title Tạo danh mục
    a.btn-back(href="/admin/categories") 
      i.fa-solid.fa-arrow-left
      | Quay lại danh sách
  .form-card
    form(action="/admin/categories/create" method="POST" enctype="multipart/form-data")
      
      //- Hàng 1: Tên & Danh mục cha
      .form-row-2
        .form-group
          label Tên danh mục
          input.form-control(type="text" name="title" placeholder="Nhập tên danh mục..." required)
        
        .form-group
          label Danh mục cha
          select.form-control(name="parent_id")
            option(value="") -- Chọn danh mục --
            option(value="1") Danh mục 1
            option(value="2") Danh mục 2
      
      //- Hàng 2: Vị trí & Trạng thái
      .form-row-2
        .form-group
          label Vị trí
          input.form-control(type="number" name="position" placeholder="Tự động tăng" min="1")
        
        .form-group
          label Trạng thái
          select.form-control(name="status")
            option(value="active") Hoạt động
            option(value="inactive") Tạm dừng

      //- Hàng 3: Khối Upload Ảnh
      .form-group
        label Ảnh đại diện
        .upload-image-wrapper
          //- Ô input file bị ẩn đi, chỉ hiện UI
          input#file-upload.hidden-input(type="file" name="thumbnail" accept="image/*" onchange="previewImage(event)")
          
          //- Giao diện nút bấm [+]
          label.upload-box(for="file-upload" id="upload-label")
            i.fa-solid.fa-plus
            
          //- Nơi hiển thị ảnh sau khi chọn
          .image-preview-container.hidden#preview-container
            img#image-preview(src="" alt="Preview")
            button.btn-remove-image(type="button" onclick="removeImage()" title="Xóa ảnh")
              i.fa-solid.fa-xmark

      //- Hàng 4: Mô tả
      .form-group
        label Mô tả
        textarea.form-control(name="description" rows="6" placeholder="Nhập mô tả cho danh mục này...")

      //- Nút Submit canh giữa
      .form-actions
        button.btn-submit(type="submit") Tạo mới