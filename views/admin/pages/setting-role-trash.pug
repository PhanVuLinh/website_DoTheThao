extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/pagination.pug
block main
  +alert-success(3000)
  +alert-error(3000)
  .page-header
    h1.page-title Thùng rác nhóm quyền
    a.btn-back(href=`/${pathAdmin}/setting/role/list`) 
      i.fa-solid.fa-arrow-left
      | Quay lại danh sách

  .filter-action-card
    .action-row
      +bulk-action([
        { value: "restore-all", label: "Khôi phục" },
        { value: "delete-all", label: "Xóa vĩnh viễn" }
      ])
        
      .search-box-large
        i.fa-solid.fa-magnifying-glass
        input(type="text" placeholder="Tìm kiếm nhóm quyền..." search)
        
  .table-section
    .table-responsive
      table.admin-table.table-hover
        thead
          tr
            th.text-center(width="50px")
              input(type="checkbox" check-all)
            th Tên nhóm quyền
            th Mô tả ngắn
            th Xóa bởi
            th Hành động
        
        tbody
          if roleList && roleList.length > 0
            each item in roleList
              tr
                td.text-center
                  input(type="checkbox" value=item.id name="id" check-item)
                td.font-weight-600 #{item.name}
                td #{item.description}
                td
                  .user-date
                    span.name #{item.deletedByFullName}
                    span.time #{item.deletedAtFormat}
                td
                  .action-btns
                    button.btn-restore(button-restore data-id=item.id title="Khôi phục")
                      i.fa-solid.fa-rotate-left
                    button.btn-delete(button-delete data-id=item.id title="Xóa vĩnh viễn")
                      i.fa-regular.fa-trash-can
          else 
            tr
              td(colspan="7" class="text-center" style="padding: 30px; color: #777;") Thùng rác trống. Không có nhóm quyền nào bị xóa!
    .admin-pagination
      +pagination(pagination)
  form(
    action=""
    method="POST"
    id="form-restore-item"
    data-path=`/${pathAdmin}/setting/role/restore`
  )
  
  form(
    action=""
    method="POST"
    id="form-delete-item"
    data-path=`/${pathAdmin}/setting/role/delete-destroy`
  )

  form(
    action=""
    method="POST"
    id="form-change-multi"
    data-path=`/${pathAdmin}/setting/role/change-multi-trash`
  )
    input(type="hidden" name="type")
    input(type="hidden" name="ids")
          