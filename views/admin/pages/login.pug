extends ../layouts/auth.pug

block main
  //- Vòng tròn trang trí nền
  .bg-shape.shape-1
  .bg-shape.shape-2

  .form-account-wrapper
    .form-account
      //- Header Form
      .auth-header
        .logo-icon
          i.fa-solid.fa-shield-halved
        h2.inner-title TitiSport Admin
        p.inner-desc Đăng nhập hệ thống quản trị viên

      //- Form Đăng Nhập
      form.inner-form#login-form(action="/admin/login" method="POST")
        
        // Group: Email
        .inner-group
          label.inner-label(for="email") Email quản trị
          .input-wrapper
            i.fa-regular.fa-envelope.input-icon
            input.inner-control(
              type="email"
              name="email"
              id="email"
              placeholder="admin@titisport.vn"
              required
            )
        
        // Group: Mật khẩu
        .inner-group
          label.inner-label(for="password") Mật khẩu
          .input-wrapper
            i.fa-solid.fa-lock.input-icon
            input.inner-control(
              type="password"
              name="password"
              id="password"
              placeholder="••••••••"
              required
            )
            //- Icon bật/tắt mật khẩu
            i.fa-regular.fa-eye-slash.toggle-password(onclick="togglePassword()")
        
        // Nút Đăng Nhập
        button.inner-button(type="submit") 
          | Đăng Nhập
          i.fa-solid.fa-arrow-right-to-bracket
