extends ../layouts/auth.pug
include ../mixins/alert.pug

block main
  +alert-error(3000)
  //- THÊM CLASS NÀY ĐỂ BAO TRỌN TOÀN MÀN HÌNH
  .auth-page
  
    .auth-bg-shape.auth-shape-1
    .auth-bg-shape.auth-shape-2

    .auth-form-wrapper
      .auth-form-container
        .auth-header
          .auth-logo-icon
            i.fa-solid.fa-shield-halved
          h2.auth-title TitiSport Admin
          p.auth-desc Đăng nhập hệ thống quản trị viên
        
        form.auth-form#login-form(action=`/${pathAdmin}/auth/login` method="POST")
          
          .auth-group
            label.auth-label(for="email") Email quản trị
            .auth-input-wrapper
              i.fa-regular.fa-envelope.auth-input-icon
              input.auth-control(
                type="email"
                name="email"
                id="email"
                placeholder="**********@gmail.com"
              )
          
          .auth-group
            label.auth-label(for="password") Mật khẩu
            .auth-input-wrapper
              i.fa-solid.fa-lock.auth-input-icon
              input.auth-control(
                type="password"
                name="password"
                id="password"
                placeholder="••••••••"
              )
              i.fa-regular.fa-eye-slash.auth-toggle-password.toggle-password(onclick="togglePassword()")
          
          button.auth-submit-btn(type="submit") 
            | Đăng Nhập
            i.fa-solid.fa-arrow-right-to-bracket