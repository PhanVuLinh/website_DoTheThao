extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/filter-status.pug
include ../mixins/filter-date-range.pug
include ../mixins/pagination.pug
block main
  +alert-success(3000)
  +alert-error(3000)
  .page-header
    h1.page-title Danh sách tài khoản quản trị
    a.btn-back(href=`/${pathAdmin}/setting/list`) 
        i.fa-solid.fa-arrow-left
        | Quay lại cài đặt chung

  .filter-action-card
    .filter-row
      .filter-label
        i.fa-solid.fa-filter
        span Bộ lọc
      
      +filter-status()
        
        
      select.form-select(filter-role)
        option(value="") Nhóm quyền
        each item in roleList
          option(value=item.id) #{item.name}
        
      button.btn-clear(filter-reset)
        i.fa-solid.fa-rotate-right
        | Xóa bộ lọc

    .action-row
      +bulk-action([
        { value: "delete-all", label: "xóa" },
        { value: "active", label: "Hoạt động" },
        { value: "inactive", label: "Dừng hoạt động" }
      ])
        
      .search-box-large
        i.fa-solid.fa-magnifying-glass
        input(type="text" placeholder="Tìm kiếm tài khoản..." search)
        
      .action-buttons-right
        a.btn-create(href=`/${pathAdmin}/setting/account-admin/create`)
          i.fa-solid.fa-plus
          | Tạo mới
        a(href=`/${pathAdmin}/setting/account-admin/trash`).btn-trash
          i.fa-regular.fa-trash-can
          | Thùng rác
  .table-section
    .table-responsive
      table.admin-table.table-hover
        thead
          tr
            th.text-center(width="50px")
              input(type="checkbox" check-all)
            th Họ tên
            th.text-center Ảnh đại diện
            th Email
            th Số điện thoại
            th Nhóm quyền
            th Chức vụ
            th Trạng thái
            th Hành động
        
        tbody
          each item in accountList
            tr
              td.text-center
                input(type="checkbox" value=item.id name="id" check-item)
              td.font-weight-600 #{item.fullName}
              td.text-center
                img.td-avatar(src=item.avatar alt=item.fullName)
              td.text-email #{item.email}
              td.text-phone #{item.phone}
              td #{item.role_name}
              td #{item.jobTitle}
              td
                span.badge-status(class= `${item.status === 'active' ? 'badge-active' : 'badge-inactive'}`) #{item.status == "active" ? "Hoạt động" : "Tạm dừng"}
              td
                .action-btns
                  a(href=`/${pathAdmin}/setting/account-admin/edit/${item.id}`).btn-edit
                    i.fa-regular.fa-pen-to-square
                  button.btn-delete(button-delete data-id=item.id)
                    i.fa-regular.fa-trash-can

    .admin-pagination
      +pagination(pagination)

  form(
    action=""
    method="POST"
    id="form-delete-item"
    data-path=`/${pathAdmin}/setting/account-admin/delete`
  )
  form(
    action=""
    method="POST"
    id="form-change-multi"
    data-path=`/${pathAdmin}/setting/account-admin/change-multi`
  )
    input(type="hidden" name="type")
    input(type="hidden" name="ids")
