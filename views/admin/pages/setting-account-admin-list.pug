extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/filter-status.pug
include ../mixins/filter-date-range.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("account_admin_view"))
    +alert-success(3000)
    +alert-error(3000)
    .page-header
      h1.page-title Danh sách tài khoản quản trị
      a.btn-back(href=`/${pathAdmin}/setting/list`) 
        i.fa-solid.fa-arrow-left
        | Quay lại cài đặt chung

    .filter-action-card
      .filter-row
        .filter-label
          i.fa-solid.fa-filter
          span Bộ lọc
        
        +filter-status()
          
        select.form-select(filter-role)
          option(value="") Nhóm quyền
          each item in roleList
            option(value=item.id) #{item.name}
          
        button.btn-clear(filter-reset)
          i.fa-solid.fa-rotate-right
          | Xóa bộ lọc

      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("account_admin_delete")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa" });
            }
            if(role.permissions.includes("account_admin_edit")) {
              bulkOptions.push({ value: "active", label: "Hoạt động" });
              bulkOptions.push({ value: "inactive", label: "Dừng hoạt động" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)
          
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm tài khoản..." search)
          
        .action-buttons-right
          if(role && role.permissions && role.permissions.includes("account_admin_create"))
            a.btn-create(href=`/${pathAdmin}/setting/account-admin/create`)
              i.fa-solid.fa-plus
              | Tạo mới
          if(role && role.permissions && role.permissions.includes("account_admin_trash"))
            a(href=`/${pathAdmin}/setting/account-admin/trash`).btn-trash
              i.fa-regular.fa-trash-can
              | Thùng rác

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Họ tên
              th.text-center Ảnh đại diện
              th Email
              th Số điện thoại
              th Nhóm quyền
              th Chức vụ
              th Trạng thái
              if(role && role.permissions && (role.permissions.includes("account_admin_edit") || role.permissions.includes("account_admin_delete")))
                th Hành động
          
          tbody
            each item in accountList
              tr
                td.text-center
                  input(type="checkbox" value=item.id name="id" check-item)
                td.font-weight-600 #{item.fullName}
                td.text-center
                  img.td-avatar(src=item.avatar alt=item.fullName)
                td.text-email #{item.email}
                td.text-phone #{item.phone}
                td #{item.role_name}
                td #{item.jobTitle}
                td
                  span.badge-status(class= `${item.status === 'active' ? 'badge-active' : 'badge-inactive'}`) #{item.status == "active" ? "Hoạt động" : "Tạm dừng"}
                if(role && role.permissions && (role.permissions.includes("account_admin_edit") || role.permissions.includes("account_admin_delete")))
                  td
                    .action-btns
                      if(role && role.permissions && role.permissions.includes("account_admin_edit"))
                        a(href=`/${pathAdmin}/setting/account-admin/edit/${item.id}`).btn-edit
                          i.fa-regular.fa-pen-to-square
                      if(role && role.permissions && role.permissions.includes("account_admin_delete"))
                        button.btn-delete(button-delete data-id=item.id)
                          i.fa-regular.fa-trash-can

    .admin-pagination
      +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("account_admin_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/setting/account-admin/delete`
      )

    if(role && role.permissions && (role.permissions.includes("account_admin_edit") || role.permissions.includes("account_admin_delete")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/setting/account-admin/change-multi`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.