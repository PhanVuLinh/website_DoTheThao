extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("category_trash"))
    +alert-success(3000)
    +alert-error(3000)

    .page-header
      h1.page-title Thùng rác danh mục
      a.btn-back(href=`/${pathAdmin}/category/list`) 
        i.fa-solid.fa-arrow-left
        | Quay lại danh sách

    .filter-action-card
      .action-row
        if(role && role.permissions && (role.permissions.includes("category_restore") || role.permissions.includes("category_destroy")))
          +bulk-action([
            { value: "restore-all", label: "Khôi phục" },
            { value: "delete-all", label: "Xóa vĩnh viễn" }
          ])
          
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm danh mục đã xóa..." search)

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Tên danh mục
              th Ảnh đại diện
              th Vị trí
              th Trạng thái
              th Xóa bởi
              if(role && role.permissions && (role.permissions.includes("category_restore") || role.permissions.includes("category_destroy")))
                th Hành động
              
          tbody
            if categoryList && categoryList.length > 0
              each item in categoryList
                tr
                  td.text-center
                    input(type="checkbox" name="id" value=item.id check-item)
                  td.font-weight-600 #{item.title}
                  td
                    img.td-thumbnail(src=item.thumbnail alt=item.title)
                  td #{item.position}
                  td
                    span.badge-status.badge-inactive Đã xóa
                  td
                    .user-date
                      span.name #{item.deletedByFullName}
                      span.time #{item.deletedAtFormat}
                  if(role && role.permissions && (role.permissions.includes("category_restore") || role.permissions.includes("category_destroy")))
                    td
                      .action-btns
                        if(role && role.permissions && role.permissions.includes("category_restore"))
                          button.btn-restore(button-restore data-id=item.id title="Khôi phục")
                            i.fa-solid.fa-rotate-left
                        if(role && role.permissions && role.permissions.includes("category_destroy"))
                          button.btn-delete(button-delete data-id=item.id title="Xóa vĩnh viễn")
                            i.fa-regular.fa-trash-can
            else
              tr
                td(colspan="7" class="text-center" style="padding: 30px; color: #777;") Thùng rác trống. Không có danh mục nào bị xóa!

    .admin-pagination
      +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("category_restore"))
      form(
        action=""
        method="POST"
        id="form-restore-item"
        data-path=`/${pathAdmin}/category/restore`
      )

    if(role && role.permissions && role.permissions.includes("category_destroy"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/category/delete-destroy`
      )

    if(role && role.permissions && (role.permissions.includes("category_restore") || role.permissions.includes("category_destroy")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/category/change-multi-trash`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.