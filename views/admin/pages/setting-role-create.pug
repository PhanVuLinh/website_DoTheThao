extends ../layouts/default.pug

block main
  .page-header
    h1.page-title Tạo nhóm quyền
    a.btn-back(href=`/${pathAdmin}/setting/role/list`) 
      i.fa-solid.fa-arrow-left
      | Quay lại danh sách

  .form-card
    form(action=`/${pathAdmin}/setting/role/create` method="POST")
      
      .form-row-2
        .form-group
          label Tên nhóm quyền
          input.form-control(type="text" name="name" placeholder="Ví dụ: Quản trị viên")
        
        .form-group
          label Mô tả ngắn
          input.form-control(type="text" name="description" placeholder="Ví dụ: Có đầy đủ các quyền")

      .form-row-2
        .form-group
          label Phân quyền
          .permissions-box
            each item in permissionList
              .check-item
                input(type="checkbox" name="permissions" value=item.value)
                label(for="perm-overview") #{item.label}
                
        .form-group
      .form-actions-stacked
        button.btn-submit.btn-submit-large(type="submit") Tạo mới