extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/filter-status.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("user_view"))
    +alert-success(3000)
    +alert-error(3000)
    h1.page-title Danh sách khách hàng

    .filter-action-card
      .filter-row
        .filter-label
          i.fa-solid.fa-filter
          span Bộ lọc
        
        +filter-status()
                
        button.btn-clear(filter-reset)
          i.fa-solid.fa-rotate-right
          | Xóa bộ lọc

      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("user_delete")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa nhiều" });
            }
            if(role.permissions.includes("user_edit")) {
              bulkOptions.push({ value: "active", label: "Hoạt động" });
              bulkOptions.push({ value: "inactive", label: "Tạm dừng" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)
          
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm theo tên, email..." search)
          
        .action-buttons-right
          if(role && role.permissions && role.permissions.includes("user_create"))
            a(href=`/${pathAdmin}/user/create`).btn-create
              i.fa-solid.fa-plus
              | Tạo mới
          if(role && role.permissions && role.permissions.includes("user_trash"))
            a(href=`/${pathAdmin}/user/trash`).btn-trash
              i.fa-regular.fa-trash-can
              | Thùng rác

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Họ và tên
              th Email
              th Trạng thái
              th Người tạo
              th Cập nhật bởi
              if(role && role.permissions && (role.permissions.includes("user_edit") || role.permissions.includes("user_delete")))
                th Hành động
          
          tbody
            if userList && userList.length > 0
              each item in userList
                tr
                  td.text-center
                    input(type="checkbox" value=item.id name="id" check-item)
                  
                  td.font-weight-600 #{item.fullName}
                  
                  td #{item.email}
                  
                  td 
                    span(class=`badge-status ${item.status === 'active' ? 'badge-active' : 'badge-inactive'}`) #{item.status === 'active' ? 'Hoạt động' : 'Tạm dừng'}
                  
                  
                  td
                    .user-date
                      span.name #{item.createdByFullName ? item.createdByFullName : 'Khách Hàng'}
                      span.time #{item.createdAtFormat}

                  td
                    .user-date
                      span.name #{item.updatedByFullName ? item.updatedByFullName : ''}
                      span.time #{item.updatedByFullName ? item.updatedAtFormat : ''}
                  
                  if(role && role.permissions && (role.permissions.includes("user_edit") || role.permissions.includes("user_delete")))
                    td
                      .action-btns
                        if(role && role.permissions && role.permissions.includes("user_edit"))
                          a(href=`/${pathAdmin}/user/edit/${item.id}`).btn-edit
                            i.fa-regular.fa-pen-to-square
                        if(role && role.permissions && role.permissions.includes("user_delete"))
                          button.btn-delete(button-delete data-id=item.id)
                            i.fa-regular.fa-trash-can
            else
              tr
                td(colspan="7" class="text-center") Không có dữ liệu khách hàng nào.
        
    .admin-pagination
      +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("user_delete"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/user/delete`
      )
            
    if(role && role.permissions && (role.permissions.includes("user_edit") || role.permissions.includes("user_delete")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/user/change-multi`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.