extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("account_admin_trash"))
    +alert-success(3000)
    +alert-error(3000)
    
    .page-header
      h1.page-title Thùng rác tài khoản quản trị
      a.btn-back(href=`/${pathAdmin}/setting/account-admin/list`) 
        i.fa-solid.fa-arrow-left
        | Quay lại danh sách

    .filter-action-card
      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("account_admin_restore")) {
              bulkOptions.push({ value: "restore-all", label: "Khôi phục" });
            }
            if(role.permissions.includes("account_admin_destroy")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa vĩnh viễn" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)
          
        .search-box-large
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm tài khoản đã xóa..." search)

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Họ tên
              th.text-center Ảnh đại diện
              th SĐT
              th Email
              th Nhóm quyền
              th Xóa ngày
              if(role && role.permissions && (role.permissions.includes("account_admin_restore") || role.permissions.includes("account_admin_destroy")))
                th Hành động
          
          tbody
            if accountList && accountList.length > 0
              each item in accountList
                tr
                  td.text-center
                    input(type="checkbox" name="id" value=item.id check-item)
                  
                  td.font-weight-600 #{item.fullName}
                  
                  td.text-center
                    img.td-avatar(src=(item.avatar || '/images/avatar-default.png') alt=item.fullName)
                  
                  td #{item.phone}
                  
                  td.text-email #{item.email}
                  
                  td #{item.role_name }
                  
                  td
                    span.time #{item.deletedAtFormat}
                  
                  if(role && role.permissions && (role.permissions.includes("account_admin_restore") || role.permissions.includes("account_admin_destroy")))
                    td
                      .action-btns
                        if(role && role.permissions && role.permissions.includes("account_admin_restore"))
                          button.btn-restore(button-restore data-id=item.id title="Khôi phục")
                            i.fa-solid.fa-rotate-left
                        if(role && role.permissions && role.permissions.includes("account_admin_destroy"))
                          button.btn-delete(button-delete data-id=item.id title="Xóa vĩnh viễn")
                            i.fa-regular.fa-trash-can
            else
              tr
                td.text-center(colspan="8" style="padding: 30px; color: #777;") Thùng rác trống. Không có tài khoản nào bị xóa!

    if pagination
      .admin-pagination
        +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("account_admin_restore"))
      form(
        action=""
        method="POST"
        id="form-restore-item"
        data-path=`/${pathAdmin}/setting/account-admin/restore`
      )
    
    if(role && role.permissions && role.permissions.includes("account_admin_destroy"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/setting/account-admin/delete-destroy`
      )

    if(role && role.permissions && (role.permissions.includes("account_admin_restore") || role.permissions.includes("account_admin_destroy")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/setting/account-admin/change-multi-trash`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.