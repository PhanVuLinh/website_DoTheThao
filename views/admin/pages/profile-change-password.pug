extends ../layouts/default.pug

block main
  //- 1. PAGE HEADER
  .page-header
    h1.page-title Đổi mật khẩu

  //- 2. FORM ĐỔI MẬT KHẨU
  .form-card
    form(action=`/${pathAdmin}/profile/change-password?_method=PATCH` method="POST")
      
      //- Hàng 1: Mật khẩu mới & Nhập lại mật khẩu mới
      .form-row-2
        .form-group
          label Mật khẩu mới
          input.form-control(type="password" name="newPassword" placeholder="Nhập mật khẩu mới" required)
        
        .form-group
          label Nhập lại mật khẩu mới
          input.form-control(type="password" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required)

      //- Nút Submit căn giữa
      .form-actions-stacked(style="margin-top: 30px;")
        button.btn-submit.btn-submit-large(type="submit") Đổi mật khẩu