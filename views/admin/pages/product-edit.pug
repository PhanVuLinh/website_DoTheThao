extends ../layouts/default.pug
include ../mixins/options.pug
include ../mixins/alert.pug

block main
  +alert-error(3000)
  +alert-success(3000)
  //- Phần Header của trang
  .page-header
    h1.page-title Chỉnh sửa sản phẩm
    a.btn-back(href=`/${pathAdmin}/product/list`) 
      i.fa-solid.fa-arrow-left
      | Quay lại danh sách

  .form-card
    form(action=`/${pathAdmin}/product/edit/${productDetail.id}?_method=PATCH` method="POST" enctype="multipart/form-data")
      
      //- Hàng 1: Tên & Danh mục
      .form-row-2
        .form-group
          label Tên sản phẩm
          input.form-control(type="text" name="title" value=productDetail.title)
        
        .form-group
          label Danh mục
          select.form-control(name="category_id")
            option(value="") -- Chọn danh mục --
            +options(categoryList,0,productDetail.category_id)
        
      //- Hàng 2: Vị trí & Trạng thái
      .form-row-2
        .form-group
          label Vị trí
          input.form-control(type="number" name="position" placeholder="Tự động tăng" value=productDetail.position)
        
        .form-group
          label Trạng thái
          select.form-control(name="status")
            option(value="active" selected=(productDetail.status === "active" ? true : false)) Hoạt động
            option(value="inactive" selected=(productDetail.status === "inactive" ? true : false)) Tạm dừng

      //- Hàng 3: Khối Upload Ảnh
      .form-group
        label Ảnh đại diện
        .upload-image-wrapper(upload-image-wrapper)
          input#thumbnail-upload.hidden-input(upload-image-input type="file" name="thumbnail" accept="image/*")
          label.upload-box(for="thumbnail-upload" upload-image-label class=(productDetail.thumbnail ? "hidden" : ""))
            i.fa-solid.fa-plus
          .image-preview-container(upload-image-preview-container class=(productDetail.thumbnail ? "" : "hidden"))
            img(upload-image-preview src=(productDetail.thumbnail ? productDetail.thumbnail : "") alt=productDetail.title)
            button.btn-remove-image(type="button" button-remove-image title="Xóa ảnh")
              i.fa-solid.fa-xmark

      //- Hàng 4: Giá bán & Phần trăm giảm giá (chia 2 cột)
      .form-row-2
        .form-group
          label Giá bán (VNĐ)
          input.form-control(type="number" name="price" placeholder="Ví dụ: 2500000" value=productDetail.price )
        
        .form-group
          label Giảm giá (%)
          input.form-control(type="number" name="discountPercentage" placeholder="Ví dụ: 15" min="0" max="100" value=productDetail.discountPercentage)

      //- Hàng 5: Quản lý tồn kho theo Size
      .form-group
        label Kho hàng theo size / kích cỡ
        #dynamic-size-list

        button.btn-add-size(type="button" onclick="addSizeField()")
          i.fa-solid.fa-plus
          |  Thêm size khác

      //- Hàng 6: Mô tả
      .form-group
        label Mô tả sản phẩm
        textarea.form-control(name="description" rows="6" placeholder="Nhập mô tả chi tiết cho sản phẩm này...") #{value=productDetail.description}

      //- Nút Submit
      .form-actions
        button.btn-submit(type="submit") Cập nhật

  script.
    window.productSizes = !{JSON.stringify(productDetail.sizes || [])};
  script(src="/admin/assets/js/product.js")