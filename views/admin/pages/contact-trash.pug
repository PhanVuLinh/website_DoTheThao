extends ../layouts/default.pug
include ../mixins/alert.pug
include ../mixins/bulk-action.pug
include ../mixins/pagination.pug

block main
  if(role && role.permissions && role.permissions.includes("contact_trash"))
    +alert-success(3000)
    +alert-error(3000)
    
    .page-header
      h1.page-title Thùng rác Email Đăng Ký
      a.btn-back(href=`/${pathAdmin}/contact/list`) 
        i.fa-solid.fa-arrow-left
        | Quay lại danh sách

    .filter-action-card
      .action-row
        - 
          var bulkOptions = [];
          if(role && role.permissions) {
            if(role.permissions.includes("contact_restore")) {
              bulkOptions.push({ value: "restore-all", label: "Khôi phục" });
            }
            if(role.permissions.includes("contact_destroy")) {
              bulkOptions.push({ value: "delete-all", label: "Xóa vĩnh viễn" });
            }
          }

        if(bulkOptions.length > 0)
          +bulk-action(bulkOptions)

        .search-box-large(style="max-width: 500px;")
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm email đã xóa..." search)

    .table-section
      .table-responsive
        table.admin-table.table-hover
          thead
            tr
              th.text-center(width="50px")
                input(type="checkbox" check-all)
              th Email đăng ký
              th Xóa bởi
              if(role && role.permissions && (role.permissions.includes("contact_restore") || role.permissions.includes("contact_destroy")))
                th Hành động
          
          tbody
            if contactList && contactList.length > 0
              each item in contactList
                tr
                  td.text-center
                    input(type="checkbox" name="id" value=item.id check-item)
                  
                  td.font-weight-600 #{item.email}
                  
                  td
                    .user-date
                      span.name #{item.deletedByFullName}
                      span.time #{item.deletedAtFormat}
                  
                  if(role && role.permissions && (role.permissions.includes("contact_restore") || role.permissions.includes("contact_destroy")))
                    td
                      .action-btns
                        if(role && role.permissions && role.permissions.includes("contact_restore"))
                          button.btn-restore(button-restore data-id=item.id title="Khôi phục")
                            i.fa-solid.fa-rotate-left
                        if(role && role.permissions && role.permissions.includes("contact_destroy"))
                          button.btn-delete(button-delete data-id=item.id title="Xóa vĩnh viễn")
                            i.fa-regular.fa-trash-can
            else 
              tr
                td(colspan="4" class="text-center" style="padding: 30px; color: #777;") Thùng rác trống. Không có email nào bị xóa!

    if pagination
      .admin-pagination
        +pagination(pagination)

    if(role && role.permissions && role.permissions.includes("contact_restore"))
      form(
        action=""
        method="POST"
        id="form-restore-item"
        data-path=`/${pathAdmin}/contact/restore`
      )
    
    if(role && role.permissions && role.permissions.includes("contact_destroy"))
      form(
        action=""
        method="POST"
        id="form-delete-item"
        data-path=`/${pathAdmin}/contact/delete-destroy`
      )

    if(role && role.permissions && (role.permissions.includes("contact_restore") || role.permissions.includes("contact_destroy")))
      form(
        action=""
        method="POST"
        id="form-change-multi"
        data-path=`/${pathAdmin}/contact/change-multi-trash`
      )
        input(type="hidden" name="type")
        input(type="hidden" name="ids")
  else
    .no-access-wrapper
      .no-access-card
        .no-access-icon
          i.fa-solid.fa-lock

        h2.no-access-title Truy cập bị từ chối

        p.no-access-desc
          | Bạn không có quyền truy cập vào trang này.
          br
          | Vui lòng liên hệ quản trị viên để được cấp quyền phù hợp.